{
  "name": "fantasy-stock",
  "version": "1.0.0",
  "description": "Fantasy Stock Trading App - Web and Mobile",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=apps/web",
    "web:build": "npm run build --workspace=apps/web",
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo start --ios",
    "mobile:android": "cd apps/mobile && npx expo start --android",
    "test:simulation": "node scripts/simulation-test-runner.mjs"
  },
  "keywords": [
    "fantasy",
    "stock",
    "trading",
    "react",
    "react-native",
    "expo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "concurrently": "^9.2.1"
  }
}
